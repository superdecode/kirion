NODE_ENV=production
PORT=3001

# PostgreSQL / Supabase Configuration
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_password_here
DB_SSL=true

# JWT
JWT_SECRET=your_production_jwt_secret_use_a_long_random_string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS - Configure with your frontend domains
CORS_ORIGIN=https://your-frontend-domain.com,https://your-frontend-domain.vercel.app

# WMS encryption key (AES-256-CBC, MUST be exactly 32 chars for production)
WMS_ENCRYPTION_KEY=CHANGE_THIS_TO_32_CHAR_SECURE_KEY_IN_PRODUCTION

# Supabase-specific (optional, for direct Supabase client usage)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
